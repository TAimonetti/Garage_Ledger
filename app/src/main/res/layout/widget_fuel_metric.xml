<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4EC"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#1F332A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/widget_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_refresh" />
    </LinearLayout>

    <TextView
        android:id="@+id/metric_title_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#1F332A"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/metric_subtitle_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#4D6158"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/metric_title_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#1F332A"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/metric_subtitle_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#4D6158"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/metric_title_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#1F332A"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/metric_subtitle_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#4D6158"
        android:textSize="12sp" />

    <Button
        android:id="@+id/widget_open_app"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/widget_open_app" />
</LinearLayout>
